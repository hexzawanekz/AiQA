# Copy this file to .env and fill in your values

# ── Option A: Z.AI / GLM (recommended — free tier available) ──────────────────
# Get key at: https://z.ai/userinfo
Z_AI_API_KEY=your-zai-key-here...

# ── Option B: Google AI Studio (FREE tier) ────────────────────────────────────
# Get key at: https://aistudio.google.com/apikey
# GOOGLE_API_KEY=AIzaSy...

# ── Option C: Anthropic Claude ────────────────────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...

# ── Option D: OpenAI GPT-4o ───────────────────────────────────────────────────
# OPENAI_API_KEY=sk-...

# LLM to use: "zai", "gemini", "claude", or "openai"
AIQA_LLM=zai
AIQA_MODEL=glm-4-flash
# For Z.AI paid:   AIQA_MODEL=glm-5
# For Gemini:      AIQA_MODEL=gemini-2.0-flash
# For Claude:      AIQA_MODEL=claude-sonnet-4-5
# For OpenAI:      AIQA_MODEL=gpt-4o

# Optional: Slack webhook for report notifications
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

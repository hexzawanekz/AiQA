# AiQA Client Config — copy to aware-cosmetics.yaml and fill in your values
# cp clients/aware-cosmetics.yaml.example clients/aware-cosmetics.yaml

store_domain: your-store.myshopify.com
store_password: ""

# Shopify Storefront API public access token
# Get from: Shopify Admin → Apps → Develop Apps → your app → Storefront API
storefront_access_token: ""

# Shopify Admin API private token (shpat_...)
# Get from: Shopify Admin → Apps → Develop Apps → your app → Admin API
# Required scopes: read_products, read_orders, read_customers, read_inventory
admin_api_token: ""

# Test cases to run (comment out any you want to skip)
test_cases:
  - catalog_search
  - data_consistency
  - visual_browse
  - add_to_cart
  - checkout_flow

# Optional: Slack webhook URL to send report on completion
slack_webhook_url: ""

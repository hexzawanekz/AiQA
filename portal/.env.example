# Rename to .env (or secrets.env on server) and fill in values.
# Never commit this file with real values. On Oracle, use e.g. /opt/agentchattr/secrets.env with chmod 600.

# Z.AI API key (for [agents.codex] when api_key_env = "ZAI_API_KEY")
ZAI_API_KEY=

# Gemini CLI on headless server (no browser). Get key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Add other agent API keys here if you add more API-type agents with api_key_env in config.local.toml
